{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "pnpm docs:build:nobase",
    "beforeDevCommand": "pnpm docs:dev",
    "devPath": "http://localhost:5173",
    "distDir": "../.vitepress/dist"
  },
  "package": {
    "productName": "Bunpou",
    "version": "1.2.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": false,
        "open": true,
        "scope": [],
        "sidecar": false
      }
    },
    "bundle": {
      "active": true,
      "category": "Education",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "cn.bunpou.desktop",
      "longDescription": "Bunpou 是一个面向日语学习者的桌面语法学习应用，提供课程化浏览、快速索引与离线例句音频。",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "离线可用的日语语法学习与查阅应用",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "center": true,
        "fullscreen": false,
        "height": 820,
        "minHeight": 720,
        "minWidth": 1120,
        "resizable": true,
        "title": "Bunpou · 日语语法学习",
        "width": 1280
      }
    ]
  }
}